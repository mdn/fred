{
  "name": "@mdn/yari",
  "version": "5.1.2",
  "repository": "https://github.com/mdn/yari",
  "license": "MPL-2.0",
  "author": "MDN Web Docs",
  "type": "module",
  "scripts": {
    "install:all": "find . -mindepth 2 -name 'yarn.lock' ! -wholename '**/node_modules/**' -print0 | xargs -n1 -0 sh -cx 'yarn --cwd $(dirname $0) install'",
    "install:all:npm": "find . -mindepth 2 -name 'package-lock.json' ! -wholename '**/node_modules/**' -print0 | xargs -n1 -0 sh -cx 'npm --prefix $(dirname $0) install'",
    "prepare": "yarn install:all && yarn install:all:npm"
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@lit/task": "^1.0.3",
    "@mdn/minimalist": "^2.0.4",
    "@mozilla/glean": "5.0.5",
    "@stripe/stripe-js": "^7.9.0",
    "@use-it/interval": "^1.0.0",
    "dayjs": "^1.11.18",
    "dexie": "^4.2.0",
    "extend": "^3.0.2",
    "lit": "^3.3.1",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-phrasing": "^4.1.0",
    "mdast-util-to-hast": "^13.2.0",
    "prism-svelte": "^0.5.0",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-modal": "^3.16.3",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.8.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sse.js": "^2.7.0",
    "swr": "^2.3.6",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22"
}
